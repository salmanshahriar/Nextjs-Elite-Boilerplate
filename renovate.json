{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":timezone(Asia/Dhaka)",
    "group:allNonMajor",
    "schedule:weekly"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Automerge safe patch/minor updates",
      "matchUpdateTypes": ["patch", "minor", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Keep major updates separate and visible",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Group React and Next ecosystem updates",
      "groupName": "next-react-ecosystem",
      "matchPackageNames": ["next", "react", "react-dom", "next-auth"]
    }
  ]
}
