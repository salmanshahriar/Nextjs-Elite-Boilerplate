{
  "name": "nextjs-elite-boilerplate",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "lint:fix": "eslint . --fix && prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "format": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "format:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml}\"",
    "knip": "knip",
    "check": "npm run typecheck && npm run lint && npm run knip && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:webkit": "playwright test --project=webkit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "^10.50.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.100.6",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.35.0",
    "@vercel/analytics": "2.0.1",
    "better-auth": "^1.6.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "ofetch": "^1.5.1",
    "pino": "^9.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.56.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "9.39.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "1.58.2",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.1",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "16.5.0",
    "jsdom": "28.1.0",
    "knip": "^6.9.0",
    "lefthook": "^1.8.0",
    "pino-pretty": "^11.2.0",
    "postcss": "8.5.12",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "storybook": "^10.3.6",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "4.2.1",
    "tsx": "^4.20.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "overrides": {
    "postcss": "8.5.12",
    "uuid": "^14.0.0"
  }
}
